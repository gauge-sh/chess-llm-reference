# Copy to .env. Every vendor choice is configuration — nothing is hardcoded.

# ── LLM ──────────────────────────────────────────────────────────────────────
# Any OpenAI-compatible chat-completions endpoint. Pick ONE gateway/model.
# The code never names a vendor; only these three values change.
LLM_BASE_URL=
LLM_API_KEY=
LLM_MODEL=

# Interchangeable examples (uncomment one and fill in the key/model):
# OpenAI            LLM_BASE_URL=https://api.openai.com/v1
# Anthropic (compat) LLM_BASE_URL=https://api.anthropic.com/v1
# A hosted gateway  LLM_BASE_URL=https://<your-gateway-host>/v1
# Local (Ollama)    LLM_BASE_URL=http://localhost:11434/v1   (LLM_API_KEY can be blank)
# Self-hosted vLLM  LLM_BASE_URL=http://localhost:8000/v1

# Optional LLM tuning
# LLM_TEMPERATURE=0.3
# LLM_MAX_TOKENS=2048
# LLM_MAX_TOOL_ITERS=8

# ── Database ─────────────────────────────────────────────────────────────────
# Any SQLAlchemy URL. Defaults to local SQLite (zero-config). For a hosted
# Postgres, set a postgresql+psycopg:// URL — works with any managed provider.
# DATABASE_URL=sqlite:///./chess.db
# DATABASE_URL=postgresql+psycopg://USER:PASSWORD@HOST:5432/DBNAME

# ── App ──────────────────────────────────────────────────────────────────────
# CORS origins allowed to call the API (comma-separated).
# CORS_ORIGINS=http://localhost:3000
