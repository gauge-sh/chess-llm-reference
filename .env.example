# Copy to .env. Every vendor choice is configuration — nothing is hardcoded.

# ── LLM ──────────────────────────────────────────────────────────────────────
# Point these at any endpoint that speaks the standard chat-completions JSON
# protocol. LLM_API_KEY may be left blank for endpoints that need no auth.
LLM_BASE_URL=
LLM_API_KEY=
LLM_MODEL=

# Optional tuning
# LLM_TEMPERATURE=0.3
# LLM_MAX_TOKENS=2048
# LLM_MAX_TOOL_ITERS=8

# ── Database ─────────────────────────────────────────────────────────────────
# Any SQLAlchemy URL. Defaults to local SQLite (zero-config). Set a
# postgresql+psycopg:// URL to use a hosted Postgres instead.
# DATABASE_URL=sqlite:///./chess.db

# ── App ──────────────────────────────────────────────────────────────────────
# Browser origins allowed to call the API (comma-separated).
# CORS_ORIGINS=http://localhost:3000
